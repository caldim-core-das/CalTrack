# =============================================================================
# CalTrack Backend — Environment Variables Template
# =============================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in every value marked <CHANGE_ME> before running the server.
# 3. NEVER commit .env — it contains real secrets.
# =============================================================================

# ── Django Core ───────────────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=<CHANGE_ME_USE_A_LONG_RANDOM_STRING>

# Set to 0 (or omit entirely) in production!
DJANGO_DEBUG=0

# Comma-separated list. Add your VPS hostname / domain here.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DB_NAME=caltrack
DB_USER=caltrack_user
DB_PASSWORD=<CHANGE_ME_STRONG_DB_PASSWORD>
DB_HOST=localhost
DB_PORT=5432

# Leave blank for local Docker PostgreSQL (no TLS).
# Set to "require" for Supabase/RDS: DB_SSLMODE=require
DB_SSLMODE=

# Statement timeout in ms (leave blank for no limit)
DB_STATEMENT_TIMEOUT=

# Seconds to keep DB connections alive (0 = close after each request)
DB_CONN_MAX_AGE=60

# ── Redis (Celery broker + Django Channels) ───────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Google OAuth ──────────────────────────────────────────────────────────────
Client_ID=<CHANGE_ME_GOOGLE_OAUTH_CLIENT_ID>.apps.googleusercontent.com
Client_secret=<CHANGE_ME_GOOGLE_OAUTH_CLIENT_SECRET>
REDIRECT_URI=http://localhost:8000/accounts/google/login/callback/

# ── Email (SMTP — used for password reset & invitations) ─────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=<CHANGE_ME_YOUR_EMAIL@example.com>
EMAIL_HOST_PASSWORD=<CHANGE_ME_APP_PASSWORD_NOT_ACCOUNT_PASSWORD>

# ── Frontend URL (used in reset-password links) ───────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── CORS (comma-separated frontend origins) ───────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── JWT Lifetimes ─────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=480
JWT_REFRESH_DAYS=7

# ── Cookie security ───────────────────────────────────────────────────────────
# "Lax" for local dev, "Strict" in production (same-origin)
AUTH_COOKIE_SAMESITE=Lax

# ── Throttling ────────────────────────────────────────────────────────────────
THROTTLE_ANON=60/minute
THROTTLE_USER=300/minute

# ── Production proxy path ─────────────────────────────────────────────────────
# Set this if Django is served at a subpath, e.g. FORCE_SCRIPT_NAME=/Caltrack
FORCE_SCRIPT_NAME=